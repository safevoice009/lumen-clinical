# Lumen Clinical LLM Safety Evaluator — Environment Variables
# Copy this file to .env and fill in your values

# Get your FREE Gemini API key from: https://aistudio.google.com/app/apikey
# Required for: Live Doctor Agent, Red-Team scenario generation, Safety Auditor
# Without this key: Falls back to curated static scenarios (still fully functional)
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Band of Agents Hackathon coordination bus parameters
VITE_BAND_API_KEY=your_band_api_key_here    # Get from band.ai with code BANDHACK26
VITE_BAND_API_BASE=https://api.band.ai/v1   # Band REST base URL

# Partner APIs for Hackathon Prizes
VITE_AIML_API_KEY=your_aiml_key_here
VITE_FEATHERLESS_API_KEY=your_featherless_key_here

# Local-first / offline privacy parameters
VITE_OLLAMA_BASE=http://localhost:11434      # Local Ollama (optional, local-first mode)

# Security parameters (Optional lock screen for public deployments)
# VITE_ACCESS_PASSCODE=LUMEN2026            # Locking passcode (e.g. for Vercel production hosting)


